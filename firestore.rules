rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Regole per la collezione Users
    match /users/{userId} {
      // Un utente può leggere e scrivere solo il proprio documento
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Regole per la collezione Groups (Households)
    match /groups/{groupId} {
      // Un utente può leggere il gruppo se il suo ID è presente nella lista groupIds del suo documento utente
      // Nota: in una struttura più complessa potremmo usare custom claims o lookup.
      // Qui per semplicità permettiamo la lettura a chi è autenticato (o si può restringere dopo l'invito)
      allow read: if request.auth != null;
      allow write: if request.auth != null;

      // Regole per le sotto-collezioni (items, expenses)
      match /items/{itemId} {
        allow read, write: if request.auth != null;
      }
      
      match /expenses/{expenseId} {
        allow read, write: if request.auth != null;
      }
    }
  }
}
