<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- ======================================================= -->
    <!-- STILI TIPOGRAFICI E GERARCHIA VISIVA (Android XML)      -->
    <!-- ======================================================= -->

    <!-- Display / Titolo Schermata principale (Es. Onboarding o Grandi Totali) -->
    <style name="TextAppearance.FarFromHome.Display" parent="TextAppearance.AppCompat">
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/forest_text_main</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Heading 1: Titoli principali delle sezioni (Es. Dispensa, Lista Spesa) -->
    <style name="TextAppearance.FarFromHome.Heading1" parent="TextAppearance.AppCompat">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">@color/forest_text_main</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Heading 2: Intestazioni interne, nomi dei gruppi e schede -->
    <style name="TextAppearance.FarFromHome.Heading2" parent="TextAppearance.AppCompat">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/forest_text_main</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Body Main: Testo di base per voci di spesa e descrizioni generali -->
    <style name="TextAppearance.FarFromHome.BodyMain" parent="TextAppearance.AppCompat">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/forest_text_main</item>
        <item name="android:textStyle">normal</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:lineSpacingMultiplier">1.2</item>
    </style>

    <!-- Body Bold: Per importi, bilanci e voci di spesa prioritarie -->
    <style name="TextAppearance.FarFromHome.BodyBold" parent="TextAppearance.AppCompat">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/forest_text_main</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Button Text: Per i pulsanti primari e accento -->
    <style name="TextAppearance.FarFromHome.Button" parent="TextAppearance.AppCompat">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/pure_white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Caption / Testo Secondario: Date, piccole note e tag -->
    <style name="TextAppearance.FarFromHome.Caption" parent="TextAppearance.AppCompat">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/sage_text_muted</item>
        <item name="android:textStyle">normal</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>
</resources>
